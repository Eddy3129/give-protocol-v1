{
  "name": "@give/protocol-v1",
  "version": "1.0.0",
  "description": "GIVE Protocol V1 - No-loss donation platform using ERC-4626 vaults and yield-generating strategies",
  "scripts": {
    "build": "forge fmt && forge build",
    "test": "forge fmt && forge test",
    "test:full": "forge fmt && FOUNDRY_PROFILE=full forge test",
    "test:fork": "forge fmt && FOUNDRY_PROFILE=fork forge test",
    "test:fuzz": "forge fmt && FOUNDRY_PROFILE=fuzz forge test",
    "test:fuzz:quick": "forge fmt && FOUNDRY_PROFILE=fuzz forge test --fuzz-runs 256",
    "test:invariant": "forge fmt && FOUNDRY_PROFILE=invariant forge test",
    "test:invariant:quick": "forge fmt && FOUNDRY_PROFILE=invariant FOUNDRY_INVARIANT_RUNS=64 FOUNDRY_INVARIANT_DEPTH=200 forge test",
    "test:fast": "FOUNDRY_PROFILE=dev-fast forge test --no-match-path 'test/fork/**:test/fuzz/**:test/invariant/**'",
    "test:verbose": "forge fmt && forge test -vvv",
    "test:gas": "forge fmt && forge test --gas-report",
    "coverage": "FOUNDRY_PROFILE=coverage forge coverage --ir-minimum --exclude-tests --report lcov --no-match-path 'test/fork/**:test/fuzz/**:test/invariant/**'",
    "coverage:full": "FOUNDRY_PROFILE=coverage forge coverage --ir-minimum --report lcov",
    "coverage:summary": "FOUNDRY_PROFILE=coverage forge coverage --ir-minimum --report summary --no-match-path 'test/fork/**:test/fuzz/**:test/invariant/**'",
    "deploy:local:all": "bash script/operations/deploy_local_all.sh",
    "frontend:smoke:local": "node script/frontend/viem-smoke.mjs --mode=local",
    "frontend:smoke:rpc": "node script/frontend/viem-smoke.mjs --mode=rpc",
    "frontend:smoke:fork": "bash script/frontend/fork-smoke.sh",
    "frontend:smoke:rpc:arbitrum": "CHAIN_CONFIG=config/chains/arbitrum.json node script/frontend/viem-smoke.mjs --mode=rpc",
    "frontend:smoke:rpc:optimism": "CHAIN_CONFIG=config/chains/optimism.json node script/frontend/viem-smoke.mjs --mode=rpc",
    "frontend:smoke:fork:arbitrum": "CHAIN_CONFIG=config/chains/arbitrum.json bash script/frontend/fork-smoke.sh",
    "frontend:smoke:fork:optimism": "CHAIN_CONFIG=config/chains/optimism.json bash script/frontend/fork-smoke.sh",
    "lint": "forge fmt --check && forge lint",
    "lint:fix": "forge fmt",
    "clean": "forge clean"
  },
  "keywords": [
    "defi",
    "donations",
    "philanthropy",
    "erc-4626",
    "yield",
    "smart-contracts",
    "foundry"
  ],
  "author": "GIVE Labs",
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^5.3.0",
    "viem": "2.46.2"
  },
  "dependencies": {
    "@openzeppelin/contracts-upgradeable": "^5.0.0"
  }
}
