# GIVE Protocol env template
# Copy to `.env` and fill all required values before deploy/E2E.

# -----------------------------------------------------------------------------
# Signers / wallets
# -----------------------------------------------------------------------------
PRIVATE_KEY=
USER_PRIVATE_KEY=
NGO_PRIVATE_KEY=
OUTSIDER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Core addresses (required by Deploy01/02/03)
# -----------------------------------------------------------------------------
ADMIN_ADDRESS=
UPGRADER_ADDRESS=
TREASURY_ADDRESS=
PROTOCOL_ADMIN_ADDRESS=
STRATEGY_ADMIN_ADDRESS=
CAMPAIGN_ADMIN_ADDRESS=
CAMPAIGN_CREATOR_ADDRESS=
CHECKPOINT_COUNCIL_ADDRESS=
CAMPAIGN_CURATOR_ADDRESS=
USER_ADDRESS=

# -----------------------------------------------------------------------------
# RPC / verification
# -----------------------------------------------------------------------------
BASE_RPC_URL=
RPC_URL=
ETHERSCAN_API_KEY=

# Deployment artifact resolution for frontend E2E (strict strongly prefers explicit)
DEPLOYMENT_NETWORK=anvil
DEPLOYMENTS_FILE=
EXPECTED_CHAIN_ID=31337

# -----------------------------------------------------------------------------
# Protocol and deployment controls
# -----------------------------------------------------------------------------
PROTOCOL_FEE_BPS=100
ALLOW_DEFAULT_BROADCAST=false
REQUIRE_AAVE_ADAPTER=true
AUTO_REBALANCE_ENABLED=true
REBALANCE_INTERVAL=86400
USE_PENDLE_AS_ACTIVE=false

# -----------------------------------------------------------------------------
# Asset/adapters (Base mainnet defaults)
# -----------------------------------------------------------------------------
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
AAVE_POOL_ADDRESS=0xA238Dd80C259a72e81d7e4664a9801593F98d1c5
PENDLE_ROUTER_ADDRESS=
PENDLE_MARKET_ADDRESS=
PENDLE_PT_ADDRESS=